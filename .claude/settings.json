{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npx prettier --write \"$CLAUDE_FILE_PATHS\""
          },
          {
            "type": "command",
            "command": "npx eslint \"$CLAUDE_FILE_PATHS\" --fix"
          },
          {
            "type": "command",
            "command": "npx tsc --noEmit"
          }
        ]
      }
    ]
  },
  "permissions": {
    "deny": [
      "Write(**/.env*)",
      "Edit(**/.env*)",
      "Bash(rm *)",
      "Bash(rm -rf *)",
      "Bash(* rm *)"
    ]
  }
}
